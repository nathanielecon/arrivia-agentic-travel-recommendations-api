{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Recommendation request rate by outcome",
      "type": "timeseries",
      "targets": [{"expr": "sum by (outcome) (rate(recommendation_requests_total[5m]))", "legendFormat": "{{outcome}}"}]
    },
    {
      "id": 2,
      "title": "Recommendation 5xx ratio",
      "type": "timeseries",
      "targets": [{"expr": "sum(rate(recommendation_requests_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(recommendation_requests_total[5m])), 1e-9)", "legendFormat": "5xx ratio"}]
    },
    {
      "id": 3,
      "title": "Recommendation latency p95",
      "type": "timeseries",
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, surface) (rate(recommendation_request_duration_seconds_bucket[5m])))", "legendFormat": "{{surface}}"}]
    },
    {
      "id": 4,
      "title": "Upstream latency p95",
      "type": "timeseries",
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, dependency) (rate(upstream_request_duration_seconds_bucket[5m])))", "legendFormat": "{{dependency}}"}]
    },
    {
      "id": 5,
      "title": "Partner-config success ratio",
      "type": "timeseries",
      "targets": [{"expr": "sum(rate(partner_config_upstream_requests_total{outcome=\"success\"}[5m])) / clamp_min(sum(rate(partner_config_upstream_requests_total[5m])), 1e-9)", "legendFormat": "success ratio"}]
    },
    {
      "id": 6,
      "title": "Circuit breaker state",
      "type": "state-timeline",
      "targets": [{"expr": "circuit_breaker_state", "legendFormat": "{{dependency}} {{state}}"}]
    },
    {
      "id": 7,
      "title": "Budget infrastructure failures",
      "type": "timeseries",
      "targets": [{"expr": "sum by (reason) (increase(budget_reservation_failures_total[5m]))", "legendFormat": "{{reason}}"}]
    },
    {
      "id": 8,
      "title": "Cruise exclusion evaluation share",
      "type": "timeseries",
      "targets": [{"expr": "sum by (partner_id) (rate(rule_evaluations_total{rule=\"exclude_cruise\",value=\"true\"}[15m])) / clamp_min(sum by (partner_id) (rate(rule_evaluations_total{rule=\"exclude_cruise\"}[15m])), 1e-9)", "legendFormat": "{{partner_id}}"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["arrivia", "recommendations", "v0"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Arrivia Recommendation API — v0 Operations",
  "uid": "arrivia-recs-v0",
  "version": 1
}
