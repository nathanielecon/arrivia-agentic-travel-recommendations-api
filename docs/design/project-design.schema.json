{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arrivia.example.invalid/schemas/project-design-1.0.json",
  "title": "Arrivia engineering project design manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "metadata",
    "project",
    "outcomes",
    "non_goals",
    "environments",
    "components",
    "interfaces",
    "dependencies",
    "requirements",
    "partitions",
    "evidence_index",
    "design_gate"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "1.0" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "repository", "owner", "target_depth", "earned_depth", "evidence_level", "claim_boundary"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "target_depth": { "enum": ["D0", "D1", "D2", "D3", "D4", "D5"] },
        "earned_depth": { "enum": ["D0", "D1", "D2", "D3", "D4", "D5"] },
        "evidence_level": { "pattern": "^E[0-6]$" },
        "claim_boundary": { "type": "string", "minLength": 1 }
      }
    },
    "outcomes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "non_goals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "environments": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/environment" } },
    "components": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/idRef" } },
    "interfaces": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/idRef" } },
    "dependencies": { "type": "string", "minLength": 1 },
    "requirements": { "type": "array", "minItems": 10, "uniqueItems": true, "items": { "pattern": "^REQ-[A-Z]+-[0-9]{3}$" } },
    "partitions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/idRef" } },
    "evidence_index": { "type": "string", "minLength": 1 },
    "design_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "status", "checklist", "limitations"],
      "properties": {
        "level": { "const": "D4" },
        "status": { "enum": ["blocked", "passed"] },
        "checklist": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/gateCheck" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "status", "baseline_sha", "candidate_ref", "last_verified", "review_trigger"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "status": { "enum": ["draft", "accepted", "implemented", "verified", "superseded"] },
        "baseline_sha": { "pattern": "^[0-9a-f]{40}$" },
        "candidate_ref": { "type": "string", "minLength": 1 },
        "last_verified": { "format": "date" },
        "review_trigger": { "type": "string", "minLength": 1 }
      }
    },
    "idRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "purpose", "evidence_ceiling"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "evidence_ceiling": { "pattern": "^E[0-6]$" }
      }
    },
    "gateCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "authority"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": { "const": "pass" },
        "authority": { "type": "string", "minLength": 1 }
      }
    }
  }
}
