{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arrivia.example.invalid/schemas/worker-task-1.0.json",
  "title": "Bounded implementation worker task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id", "goal", "owner_partition", "baseline_sha", "candidate_sha",
    "allowed_paths", "forbidden_paths", "dependency_and_interface_hashes",
    "requirement_ids", "validator_ids", "runtime_check_ids", "evidence_paths",
    "claim_ceiling", "stop_conditions", "handoff"
  ],
  "properties": {
    "task_id": { "pattern": "^TASK-[A-Z0-9-]+$" },
    "goal": { "type": "string", "minLength": 1 },
    "owner_partition": { "pattern": "^P_[a-z]+$" },
    "baseline_sha": { "pattern": "^[0-9a-f]{40}$" },
    "candidate_sha": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40}$" },
    "allowed_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "dependency_and_interface_hashes": { "type": "object", "additionalProperties": { "pattern": "^[0-9a-f]{64}$" } },
    "requirement_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "pattern": "^REQ-[A-Z]+-[0-9]{3}$" } },
    "validator_ids": { "type": "array", "items": { "type": "string" } },
    "runtime_check_ids": { "type": "array", "items": { "type": "string" } },
    "evidence_paths": { "type": "array", "items": { "type": "string" } },
    "claim_ceiling": { "pattern": "^E[0-6]$" },
    "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed_paths", "validators", "evidence_events", "open_risks", "interface_hashes"],
      "properties": {
        "changed_paths": { "type": "array", "items": { "type": "string" } },
        "validators": { "type": "array", "items": { "type": "string" } },
        "evidence_events": { "type": "array", "items": { "type": "string" } },
        "open_risks": { "type": "array", "items": { "type": "string" } },
        "interface_hashes": { "type": "object", "additionalProperties": { "pattern": "^[0-9a-f]{64}$" } }
      }
    }
  }
}
