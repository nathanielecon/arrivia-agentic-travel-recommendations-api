# Copy to `.env` for local overrides. Pydantic loads `.env` from the process working directory.
# See `arrivia_recs.config.Settings` for field names and defaults.

APP_NAME=arrivia-agentic-travel-recs
APP_ENV=local
MEMBER_SERVICE_BASE_URL=http://member-service:8081
PARTNER_CONFIG_BASE_URL=http://partner-config-service:8082
SESSION_BUDGET_STORE_PATH=.data/session_budget.sqlite3
SESSION_BUDGET_TTL_SECONDS=1800
SESSION_BUDGET_MAX_SESSIONS=10000
UPSTREAM_CONNECT_TIMEOUT_SECONDS=0.25
UPSTREAM_READ_TIMEOUT_SECONDS=1.0
UPSTREAM_WRITE_TIMEOUT_SECONDS=0.25
UPSTREAM_POOL_TIMEOUT_SECONDS=0.25
UPSTREAM_CIRCUIT_FAILURE_THRESHOLD=3
UPSTREAM_CIRCUIT_OPEN_SECONDS=30
METRICS_ENABLED=true
LOG_LEVEL=INFO
PARTNER_CONFIG_ADMIN_PORT=8082

# Compose image selection for immutable promotion/rollback. Use a real registry digest.
# ARRIVIA_RECS_IMAGE=registry.example/arrivia-recs@sha256:<verified-digest>
